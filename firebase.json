{
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "functions": {
        "source": "functions",
        "codebase": "default",
        "ignore": [
            "node_modules",
            ".git",
            "firebase-debug.log",
            "firebase-debug.*.log"
        ]
    },
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "emulators": {
        "auth": {
            "host": "127.0.0.1",
            "port": 9199
        },
        "functions": {
            "host": "127.0.0.1",
            "port": 5101
        },
        "firestore": {
            "host": "127.0.0.1",
            "port": 8180
        },
        "hosting": {
            "host": "127.0.0.1",
            "port": 5500
        },
        "ui": {
            "enabled": true,
            "port": 4100
        }
    }
}