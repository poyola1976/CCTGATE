rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES AUXILIARES ---
    
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidator() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'validador';
    }

    // Validador asignado A ESTA puerta específica
    function isValidatorForDoor() {
      return isValidator() &&
             'validatorEmails' in resource.data &&
             request.auth.token.email in resource.data.validatorEmails;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- COLECCIONES ---

    // 1. Usuarios:
    // - Admin: Control total.
    // - Validador: Lee todos (necesita ver status de licencia de sus usuarios).
    // - Usuario: Solo su propio perfil.
    match /users/{userId} {
      allow read: if isAdmin() || isValidator() || isOwner(userId);
      allow create, update: if isAdmin() || isOwner(userId);
      allow delete: if (isAdmin() || isOwner(userId)) && resource.data.role != 'admin';
    }

    // 2. Puertas (Devices):
    // - Admin: Control total.
    // - Validador: 
    //     READ: Si su email está en allowedEmails O en validatorEmails.
    //     UPDATE: Solo si su email está en validatorEmails de esa puerta.
    // - Usuario: Solo lectura si su email está en 'allowedEmails'.
    match /doors/{doorId} {
      allow read: if isAdmin() || 
                   (isAuthenticated() && 
                    (request.auth.token.email in resource.data.get('allowedEmails', []) ||
                     ('validatorEmails' in resource.data && 
                      request.auth.token.email in resource.data.validatorEmails)));
      allow update: if isAdmin() || isValidatorForDoor();
      allow create, delete: if isAdmin();
    }

    // 3. Logs de Acceso:
    match /access_logs/{logId} {
      allow read: if isAdmin() || isValidator() ||
                   (isAuthenticated() && 
                    get(/databases/$(database)/documents/doors/$(resource.data.doorId)).data.allowedEmails.hasAny([request.auth.token.email]));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // 4. Settings:
    match /settings/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 5. Cámaras CCTV:
    match /cameras/{cameraId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 6. Configuración global (precios, etc):
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
